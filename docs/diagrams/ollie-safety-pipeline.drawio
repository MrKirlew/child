        <mxCell id="s_sys" value="sent with request (soft)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d6b656;fontColor=#7a5b00;fontSize=10;" edge="1" parent="1" source="sys_prompt" target="gemini">
