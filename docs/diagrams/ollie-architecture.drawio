        <!-- direct WebSocket: client JS -> gemini live (animated, routed right corridor x=1120) -->
        <mxCell id="e_js_live" value="WebSocket (direct) — audio in / audio out&#xa;via signed URL from /api/ai/live-token" style="edgeStyle=orthogonalEdgeStyle;flowAnimation=1;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.95;exitY=1;exitDx=0;exitDy=0;entryX=0.17;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=2;fontColor=#4b2e63;" edge="1" parent="1" source="c_js" target="g_live">
