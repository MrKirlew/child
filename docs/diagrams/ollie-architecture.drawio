        <!-- JS <-> storage -->
        <mxCell id="e_js_store" value="read / write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;startFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontColor=#205520;" edge="1" parent="1" source="c_js" target="c_store">
          <mxGeometry relative="1" as="geometry" />
