        <!-- JS -> backend endpoints -->
        <mxCell id="e_js_gen" value="POST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_js" target="b_gen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_js_speak" value="POST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_js" target="b_speak">
          <mxGeometry relative="1" as="geometry" />
