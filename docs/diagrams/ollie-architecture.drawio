        <!-- server errors -> sentry -->
        <mxCell id="e_err_sentry" value="server" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#4b2e63;" edge="1" parent="1" source="b_err" target="s_sentry">
          <mxGeometry relative="1" as="geometry">
