        <mxCell id="e_web_js" value="hosts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontColor=#1a3c66;" edge="1" parent="1" source="c_web" target="c_js">
