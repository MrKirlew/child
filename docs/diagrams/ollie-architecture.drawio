          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- backend -> gemini -->
        <mxCell id="e_gen_text" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.45;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="b_gen" target="g_text">
