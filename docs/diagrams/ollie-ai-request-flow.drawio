<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Ollie-AI-Request-Flow">
    <mxGraphModel dx="1500" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1460" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Ollie — AI Tutor Request Flow  (child talks to Ollie)" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ===== Fragments (behind lifelines) ===== -->
        <mxCell id="frameA" value="VOICE PATH (primary)" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontStyle=1;fontColor=#1a3c66;width=180;height=26;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="1340" height="378" as="geometry" />
        </mxCell>
        <mxCell id="frameB" value="REST TEXT PATH (typed / fallback)" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;fontStyle=1;fontColor=#8a5a00;width=240;height=26;" vertex="1" parent="1">
          <mxGeometry x="40" y="548" width="1340" height="442" as="geometry" />
        </mxCell>

        <!-- ===== Lifelines ===== -->
        <mxCell id="ll_child" value="Child" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="200" height="920" as="geometry" />
        </mxCell>
        <mxCell id="ll_fe" value="Frontend&#xa;(speech.js / ai.js)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="200" height="920" as="geometry" />
        </mxCell>
        <mxCell id="ll_api" value="Vercel  /api&#xa;(serverless proxy)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="200" height="920" as="geometry" />
        </mxCell>
        <mxCell id="ll_gem" value="Google Gemini" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#ffe0b3;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="80" width="200" height="920" as="geometry" />
        </mxCell>

        <!-- ===================== MESSAGES ===================== -->
        <!-- VOICE PATH -->
        <mxCell id="m1" value="tap 🎤 → startConversation()" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.0978;entryX=0.5;entryY=0.0978;" edge="1" parent="1" source="ll_child" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="GET /api/ai/live-token" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.1435;entryX=0.5;entryY=0.1435;" edge="1" parent="1" source="ll_fe" target="ll_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="signed WSS URL (API key server-side)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.1870;entryX=0.5;entryY=0.1870;" edge="1" parent="1" source="ll_api" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="open WebSocket · setup{ systemInstruction = sysPmt() }" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;exitX=0.5;exitY=0.2326;entryX=0.5;entryY=0.2326;" edge="1" parent="1" source="ll_fe" target="ll_gem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="speak into mic" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;exitX=0.5;exitY=0.2783;entryX=0.5;entryY=0.2783;" edge="1" parent="1" source="ll_child" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="realtimeInput: PCM 16k audio  (no input filter)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;exitX=0.5;exitY=0.3217;entryX=0.5;entryY=0.3217;" edge="1" parent="1" source="ll_fe" target="ll_gem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="inputTranscription (child transcript)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.3652;entryX=0.5;entryY=0.3652;" edge="1" parent="1" source="ll_gem" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="modelTurn audio + outputTranscription" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.4087;entryX=0.5;entryY=0.4087;" edge="1" parent="1" source="ll_gem" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m9" value="play audio (Web Audio) + show bubble" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.4543;entryX=0.5;entryY=0.4543;" edge="1" parent="1" source="ll_fe" target="ll_child">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- REST TEXT PATH -->
        <mxCell id="m10" value="type text → sendTyped() / aiGenerate()" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.5435;entryX=0.5;entryY=0.5435;" edge="1" parent="1" source="ll_child" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m11" value="POST /api/ai/generate { sysPmt, maxTok 300, temp 0.7 }" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.5891;entryX=0.5;entryY=0.5891;" edge="1" parent="1" source="ll_fe" target="ll_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m12" value="gemini-2.5-flash + SAFETY  (fallback 2.0-flash · 3 retries)" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.6326;entryX=0.5;entryY=0.6326;" edge="1" parent="1" source="ll_api" target="ll_gem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m13" value="candidates[0]…text" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.6761;entryX=0.5;entryY=0.6761;" edge="1" parent="1" source="ll_gem" target="ll_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m14" value="JSON { text }" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.7196;entryX=0.5;entryY=0.7196;" edge="1" parent="1" source="ll_api" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m15" value="speak(): POST /api/ai/speak   (Live path → ask model to say it)" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.7652;entryX=0.5;entryY=0.7652;" edge="1" parent="1" source="ll_fe" target="ll_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m16" value="gemini-2.5-flash-preview-tts" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.8087;entryX=0.5;entryY=0.8087;" edge="1" parent="1" source="ll_api" target="ll_gem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m17" value="base64 PCM audio" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.8522;entryX=0.5;entryY=0.8522;" edge="1" parent="1" source="ll_gem" target="ll_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m18" value="audio" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;exitX=0.5;exitY=0.8957;entryX=0.5;entryY=0.8957;" edge="1" parent="1" source="ll_api" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="m19" value="addBub('ai') + play TTS" style="html=1;verticalAlign=bottom;endArrow=block;exitX=0.5;exitY=0.9413;entryX=0.5;entryY=0.9413;" edge="1" parent="1" source="ll_fe" target="ll_child">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Error / fallback note ===== -->
        <mxCell id="errnote" value="Error / fallback handling:&#xa;• all models fail → 503 “All models unavailable” → UI shows “Hmm, I had a hiccup!”      • TTS fail → show text only (no robotic fallback voice)&#xa;• Live API disconnect → auto-reconnect after 1s      • content blocked (Gemini blockReason) → currently UNHANDLED (passed through as-is)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#7a5b00;" vertex="1" parent="1">
          <mxGeometry x="60" y="1018" width="1280" height="80" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend4" value="Legend:  solid black ▶ = synchronous call    dashed open ▷ = async / streaming    grey dashed = return    Frontend↔Gemini crosses the Vercel line = direct WebSocket (proxy bypassed)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="1102" width="1380" height="20" as="geometry" />
        </mxCell>
