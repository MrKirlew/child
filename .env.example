# Copy to server/.env for local Express dev server, or set in Vercel
# project env vars for production. Never commit a real .env file.

# Required — Google Generative Language API key
GOOGLE_AI_KEY=

# Local Express dev server port (server/index.js)
PORT=3456

# Observability (all optional — Sentry no-ops when DSN unset)
SENTRY_DSN=
APP_ENV=development
APP_VERSION=dev
GIT_SHA=dev
LOG_LEVEL=info
SENTRY_TRACES_SAMPLE_RATE=0.1
